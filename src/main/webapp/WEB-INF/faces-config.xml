<?xml version="1.0" encoding="UTF-8"?>

<faces-config
    xmlns="https://jakarta.ee/xml/ns/jakartaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
    https://jakarta.ee/xml/ns/jakartaee/web-facesconfig_4_1.xsd"
    version="4.1">

<!-- 4.1 on 31-12-2025
    default changed to en on 26-01-2019   -->
<application>
     <locale-config>
         <default-locale>en</default-locale>
         <supported-locale>fr</supported-locale>
         <supported-locale>nl</supported-locale>
         <supported-locale>us</supported-locale>
         <supported-locale>de</supported-locale>
         <supported-locale>es</supported-locale>
     </locale-config>
    <managed-bean>
        <managed-bean-name>currentDate</managed-bean-name>
        <managed-bean-class>java.util.Date</managed-bean-class>
        <managed-bean-scope>request</managed-bean-scope>
    </managed-bean>

<message-bundle>messages</message-bundle>
<!-- se trouve sous WEB-INF/META-INF 
sous la forme messages_fr.properties
dans fichier .xhtml on utilise : value="#{msg['button.inscription.create']}"
on utilise msg qui provient du <var> -->
<resource-bundle>
    <base-name>/messages</base-name>
    <var>msg</var>
</resource-bundle>

<!-- new 09/05/2013 used in CourseController, init(), config in faces-config.xml-->
<resource-bundle>
    <base-name>/golflc_settings</base-name>
    <var>settings</var>
</resource-bundle>

<resource-bundle>
    <base-name>/Bundle</base-name>
    <var>bundle</var>
</resource-bundle>
<!--  http://www.mkyong.com/jsf2/jsf-2-0-and-resource-bundles-example/ -->
  <resource-bundle>
	<base-name>version_components</base-name>
	<var>ver</var>
   </resource-bundle>

<navigation-rule>
        <display-name>login.xhtml</display-name>
        <from-view-id>/login.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/login.xhtml</to-view-id>
            <redirect />
        </navigation-case>
 </navigation-rule>

      <system-event-listener>
   <!--  enlevé 31-08-2025 started with  @WebListener   <system-event-listener-class>listeners.CustomSystemEventListener</system-event-listener-class>  -->
         <system-event-class>jakarta.faces.event.PostConstructApplicationEvent</system-event-class>
         <system-event-class>jakarta.faces.event.PreDestroyApplicationEvent</system-event-class>
      </system-event-listener>
   <!--   </system-event-listener>
       Before Application is to shut down 
      <system-event-listener>
         <system-event-listener-class>listeners.CustomSystemEventListener</system-event-listener-class>
         -->

<!--  added 27/11/2013  used by primefaces dialog framework
http://www.javacodegeeks.com/2015/01/primefaces-opening-external-pages-in-dynamically-generated-dialog.html 
https://primefaces.github.io/primefaces/10_0_0/#/core/dialogframework -->
<action-listener>
    org.primefaces.application.DialogActionListener
</action-listener>
<navigation-handler>
    org.primefaces.application.DialogNavigationHandler
</navigation-handler>
<view-handler>
    org.primefaces.application.DialogViewHandler
</view-handler>


 <!-- remis 31-08-2025 INDISPENSABLE sinon page blanche !! https://primefaces.github.io/primefaces/16_0_0/#/core/errorhandling -->
    <el-resolver>
         org.primefaces.application.exceptionhandler.PrimeExceptionHandlerELResolver
    </el-resolver>

</application>
 <!-- new 15/07/2022 
https://primefaces.github.io/primefaces/11_0_0/#/core/errorhandling -->
<factory>
    <exception-handler-factory>org.primefaces.application.exceptionhandler.PrimeExceptionHandlerFactory</exception-handler-factory>
 <!--   enlevé 31-08-2025<exception-handler-factory>org.omnifaces.exceptionhandler.ViewExpiredExceptionHandlerFactory</exception-handler-factory>
    <exception-handler-factory>org.omnifaces.exceptionhandler.FacesMessageExceptionHandlerFactory</exception-handler-factory>-->
</factory>

<!-- FullAjaxExceptionHandlerFactory supprimé 2026-04-09 : en tant que couche externe,
     il interceptait les exceptions avant PrimeFaces et empêchait pfExceptionHandler
     d'être alimenté → error_throw.xhtml affichait des champs vides.
     PrimeExceptionHandlerFactory gère déjà les exceptions AJAX et non-AJAX. -->

</faces-config>