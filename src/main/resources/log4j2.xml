<?xml version="1.0" encoding="UTF-8"?>
<!-- used with NB 12.0 beta 2
https://logging.apache.org/log4j/2.x/manual/appenders.html status was "TRACE"
-->
<Configuration status="WARN"
               name="XMLConfigLC"
          > 
 <!--<Properties> mod 25-01-2025
      <Property name="basePath">C:/log</Property>
      <Property name="logfileName">C:/log/golflc.log</Property>
 </Properties>
 -->
 <Properties>
    <Property name="basePath">C:/log</Property>
    <Property name="logfileName">${basePath}/golflc.log</Property>
</Properties>
 
 <Appenders>
   <File name="LogFile"
         fileName="${logfileName}"
         append="false" 
         bufferedIO="true"
         bufferSize="8192"
         immediateFlush="true">
 <PatternLayout
     charset="UTF-8"
     header="This is the log4j2 logging file of GolfLC hé àà\n\n"
     pattern="%sequenceNumber %date{ISO8601} %-6relative  %level{length=6} %class{5} . %method %line : %message %n" >
 </PatternLayout>
   </File>
   <Console name="STDOUT" target="SYSTEM_OUT">
       <PatternLayout pattern="%d{ISO8601} %-4r %level{length=5} %C %M %F - %m%n"/>
   </Console>
   </Appenders>
   <Loggers>
        <Logger name="org.apache.logging.log4j.xml"
                level="debug">
        </Logger>
        <Root level="debug">
            <AppenderRef ref="LogFile" level="debug" /> 
            <AppenderRef ref="STDOUT"  level="debug"/>
        </Root>
   </Loggers>
</Configuration>