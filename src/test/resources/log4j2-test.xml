<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" name="TestConfig">
    <Properties>
        <Property name="logfileName">C:/log/golflcTest.log</Property>
    </Properties>
    <Appenders>
        <File name="LogFile"
              fileName="${logfileName}"
              append="false"
              bufferedIO="true"
              bufferSize="8192"
              immediateFlush="true">
            <PatternLayout
                charset="UTF-8"
                header="This is the log4j2 logging file for GolfLC Tests&#10;&#10;"
                pattern="%sequenceNumber %date{ISO8601} %-6relative  %level{length=6} %class{5} . %method %line : %message %n" />
        </File>
        <Console name="STDOUT" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{ISO8601} %-4r %level{length=5} %C %M %F - %m%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="debug">
            <AppenderRef ref="LogFile" level="debug" />
            <AppenderRef ref="STDOUT"  level="info"/>
        </Root>
    </Loggers>
</Configuration>
