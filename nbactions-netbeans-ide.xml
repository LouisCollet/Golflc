<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <!-- =========================
         RUN SINGLE INTEGRATION TEST
         ========================= -->
    <action>
        <actionName>run.single.IT</actionName>
        <displayName>Run Single IT</displayName>

        <packagings>
            <packaging>*</packaging>
        </packagings>

        <goals>
            <goal>failsafe:integration-test</goal>
        </goals>

        <prompt>
            <message>Nom complet de la classe IT à exécuter (ex: sql_test.UpdateSqlBuilderAllTablesIT) :</message>
            <property>packageClassName</property>
        </prompt>

        <properties>
            <!-- Passe la classe choisie au plugin failsafe -->
            <it.test.class>${packageClassName}</it.test.class>

            <!-- JVM options -->
            <Env.JAVA_HOME>C:\Program Files\Java\jdk-25</Env.JAVA_HOME>
            <Env.MAVEN_OPTS>--enable-preview</Env.MAVEN_OPTS>

            <!-- Failsafe options -->
            <forkCount>0</forkCount>
            <reuseForks>false</reuseForks>
        </properties>
    </action>

    <!-- =========================
         TEST SINGLE (UNIT TEST)
         ========================= -->
    <action>
        <actionName>test.single</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>test-compile</goal>
            <goal>surefire:test</goal>
        </goals>
        <properties>
            <test>${packageClassName}</test>
            <Env.JAVA_HOME>C:\Program Files\Java\jdk-25</Env.JAVA_HOME>
            <argLine>--enable-preview</argLine>
        </properties>
    </action>

    <!-- =========================
         REBUILD
         ========================= -->
    <action>
        <actionName>rebuild</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>clean</goal>
            <goal>install</goal>
        </goals>
        <properties>
            <Env.MAVEN_OPTS>-Djansi.passthrough=false --enable-preview</Env.MAVEN_OPTS>
        </properties>
    </action>

</actions>
