    <!-- ================================================= -->
    <!-- =============== UNIT TESTS (UT) ================= -->
    <!-- ================================================= -->

    <!-- Test File (UT) - NetBeans standard -->
    <!-- Utilisé automatiquement sur clic droit fichier -->
    <action>
        <actionName>test.single</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>test</goal>
        </goals>
        <activatedProfiles>
            <activatedProfile>fast-ut</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Run Single UT (clic droit fichier *Test.java) 
    compile tout ! voir custom it qui fonctionne bien !! -->
    <action>
        <actionName>CUSTOM-UT-run-single</actionName>
        <displayName>Run Single UT Fast</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
          <!--  <goal>test</goal> -->
             <goal>org.codehaus.mojo:exec-maven-plugin:3.6.3:java</goal>
        </goals>
        <properties>
            <!-- NetBeans injecte automatiquement le nom de la classe -->
            
         <exec.mainClass>${packageClassName}</exec.mainClass>
         <exec.classpathScope>runtime</exec.classpathScope>
            <!-- Affichage du nom de la classe dans la console -->

           <!-- Classpath minimal -->
            <!-- Important pour éviter l'usage du nom de fichier -->
            <surefire.useFile>false</surefire.useFile>
        </properties>
        <activatedProfiles>
            <activatedProfile>fast-ut</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Debug Test File (UT) -->
    <action>
        <actionName>debug.test.single</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>test</goal>
        </goals>
        <properties>
            <maven.surefire.debug>-Xdebug -Xrunjdwp:transport=dt_socket,server=n,address=${jpda.address}</maven.surefire.debug>
            <jpda.listen>true</jpda.listen>
        </properties>
        <activatedProfiles>
            <activatedProfile>fast-ut</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Debug Single UT -->
    <action>
        <actionName>CUSTOM-UT-debug-single</actionName>
        <displayName>Debug Single UT</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>test</goal>
        </goals>
        <properties>
            <test>${className}</test>
            
            <maven.surefire.debug>-Xdebug -Xrunjdwp:transport=dt_socket,server=n,address=${jpda.address}</maven.surefire.debug>
            <jpda.listen>true</jpda.listen>
        </properties>
        <activatedProfiles>
            <activatedProfile>fast-ut</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Run all UT -->
    <action>
        <actionName>CUSTOM-UT-run-all</actionName>
        <displayName>Run All Unit Tests</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>test</goal>
        </goals>
        <activatedProfiles>
            <activatedProfile>fast-ut</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- ================================================= -->
    <!-- ============ INTEGRATION TESTS (IT) ============= -->
    <!-- ================================================= -->

    <!-- Run Single UT (No Compile) — même approche que IT qui fonctionne bien -->
    <action>
        <actionName>CUSTOM-UT-fast-single</actionName>
        <displayName>Run Single UT (No Compile)</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>surefire:test</goal>
        </goals>
        <properties>
            <test>${className}</test>
            <surefire.useFile>false</surefire.useFile>
        </properties>
        <activatedProfiles>
            <activatedProfile>fast-ut</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Run Single IT (clic droit fichier *IT.java)
    fonctionne bien !!-->
    <action>
        <actionName>CUSTOM-IT-run-single</actionName>
        <displayName>Run Single IT Fast</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>failsafe:integration-test</goal>
        </goals>
        <properties>
            <!-- NetBeans injecte automatiquement le nom de la classe -->
            <it.test>${className}</it.test>
            <!-- Important pour éviter l'usage du nom de fichier -->
            <failsafe.useFile>false</failsafe.useFile>
            <!-- JVM -->
            <Env.MAVEN_OPTS>--enable-preview</Env.MAVEN_OPTS>
        </properties>
        <activatedProfiles>
            <activatedProfile>fast-it</activatedProfile> <!--  voir dans pom.xml -->
        </activatedProfiles>
    </action>

    <!-- Debug Single IT -->
    <action>
        <actionName>CUSTOM-IT-debug-single</actionName>
        <displayName>Debug Single IT</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>failsafe:integration-test</goal>
        </goals>
        <properties>
            <it.test>${className}</it.test>
            <maven.failsafe.debug>-Xdebug -Xrunjdwp:transport=dt_socket,server=n,address=${jpda.address}</maven.failsafe.debug>
            <jpda.listen>true</jpda.listen>
        </properties>
        <activatedProfiles>
            <activatedProfile>fast-it</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Run all IT -->
    <action>
        <actionName>CUSTOM-IT-run-all</actionName>
        <displayName>Run All IT (Fast)</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>failsafe:integration-test</goal>
        </goals>
        <activatedProfiles>
            <activatedProfile>fast-it</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- Verify IT (lifecycle complet) -->
    <action>
        <actionName>CUSTOM-IT-verify</actionName>
        <displayName>Verify IT</displayName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>verify</goal>
        </goals>
        <activatedProfiles>
            <activatedProfile>fast-it</activatedProfile>
        </activatedProfiles>
    </action>

    <!-- ================================================= -->
    <!-- ================= PROJECT ====================== -->
    <!-- ================================================= -->

    <action>
        <actionName>clean</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>clean</goal>
        </goals>
    </action>

    <action>
        <actionName>rebuild</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>clean</goal>
            <goal>package</goal>
        </goals>
    </action>


