    <action>
        <actionName>CUSTOM-run-current</actionName>
        <displayName>Run Current Main (Compile-on-Save)</displayName>

        <packagings>
            <packaging>*</packaging>
        </packagings>

        <goals>
            <!-- Utilisation du plugin exec:java pour que Maven fournisse le classpath complet -->
            <goal>org.codehaus.mojo:exec-maven-plugin:3.6.3:java</goal>
        </goals>

        <properties>
            <!-- Classe principale de la source actuellement sélectionnée -->
            <exec.mainClass>${packageClassName}</exec.mainClass>

            <!-- Classpath Maven runtime complet -->
            <exec.classpathScope>runtime</exec.classpathScope>

            <!-- VM arguments éventuels (par ex. preview features) -->
            <exec.vmArgs>--enable-preview</exec.vmArgs>

            <!-- Arguments passés à main (facultatif) -->
            <!-- <exec.args>arg1 arg2</exec.args> -->

            <!-- Pas de recompilation globale -->
            <skipTests>true</skipTests>
        </properties>
    </action>

