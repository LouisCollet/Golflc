<action>
    <actionName>CUSTOM-main-single</actionName>
    <displayName>Run Single Main</displayName>
    <packagings>
        <packaging>*</packaging>
    </packagings>
    <goals>
        <goal>process-classes</goal>
        <goal>exec:java</goal>
    </goals>
    <properties>
        <!-- ✅ Propriété standard reconnue par exec-maven-plugin -->
        <exec.mainClass.pom>${className}</exec.mainClass.pom>
        
        <!-- Arguments JVM (pas d'application) -->
        <exec.vmArgs>--enable-preview</exec.vmArgs>
        <!-- Arguments de l'application (si besoin) -->
        <!-- <exec.args>arg1 arg2</exec.args> -->
        <!-- Classpath -->
        <exec.classpathScope>runtime</exec.classpathScope>
        <!-- Skip tests -->
        <skipTests>true</skipTests>
    </properties>
    <!-- Pas besoin de profil pour exécuter un main -->
</action>
